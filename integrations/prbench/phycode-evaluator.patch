+def resolve_phycode_env() -> dict[str, str]:
+    """Resolve only the provider variables consumed by the PhyCode runner."""
+    env: dict[str, str] = {}
+    for name in PHYCODE_PROVIDER_NAMES:
+        value = os.environ.get(name, "").strip()
+        if value:
+            env[name] = value
+    return env
+
+
+def clear_phycode_environment(
+    provider_env: dict[str, str], process_env: dict[str, str] | None = None,
+) -> None:
+    """Remove white-provider values from every transient host mapping."""
+    provider_env.clear()
+    for name in PHYCODE_PROVIDER_NAMES:
+        os.environ.pop(name, None)
+        if process_env is not None:
+            process_env.pop(name, None)
+
+
+def run_with_phycode_cleanup(action, provider_env, process_env=None):
+    """Run one spawn action and clear credentials on success or failure."""
+    try:
+        return action()
+    finally:
+        clear_phycode_environment(provider_env, process_env)
+
+
+def _build_opencode_config_content(provider_env: dict[str, str]) -> str:
+    """Build a child-only OpenCode provider registry without embedding its key."""
+    model = provider_env.get("OPENCODE_MODEL", "")
+    base_url = provider_env.get("OPENAI_BASE_URL", "")
+    if not base_url or not model.startswith("openai_compat/"):
+        return ""
+    model_name = model.split("/", 1)[1]
+    if not model_name:
+        return ""
+    return json.dumps({
+        "model": model,
+        "provider": {
+            "openai_compat": {
+                "npm": "@ai-sdk/openai-compatible",
+                "name": "OpenAI Compatible",
+                "options": {
+                    "baseURL": base_url,
+                    "apiKey": "{env:OPENAI_API_KEY}",
+                },
+                "models": {model_name: {}},
+            }
+        },
+    })
+
+
+def build_green_child_environment(
+    agent_type: str,
+) -> tuple[list[str], dict[str, str], dict[str, str]]:
+    """Build name-only Docker flags and one transient green child environment."""
+    provider_env = resolve_env(agent_type)
+    if agent_type == "opencode":
+        config_content = _build_opencode_config_content(provider_env)
+        if config_content:
+            provider_env["OPENCODE_CONFIG_CONTENT"] = config_content
+    process_env = os.environ.copy()
+    process_env.update(provider_env)
+    process_env["HOME"] = "/home/agent"
+
+    env_flags: list[str] = []
+    for name in ("HOME", *provider_env):
+        env_flags.extend(["-e", name])
+    return env_flags, provider_env, process_env
+
+
+def clear_green_child_environment(
+    provider_env: dict[str, str], process_env: dict[str, str],
+) -> None:
+    """Clear every mapping that temporarily held green-provider values."""
+    provider_env.clear()
+    process_env.clear()
+
+
