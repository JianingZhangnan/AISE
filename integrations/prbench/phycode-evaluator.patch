+def _phycode_workspace_identity(workspace_dir: str) -> tuple[str, int, int]:
+    workspace = os.lstat(workspace_dir)
+    if (
+        not stat.S_ISDIR(workspace.st_mode)
+        or stat.S_ISLNK(workspace.st_mode)
+        or _is_reparse_point(workspace)
+    ):
+        raise RuntimeError("PhyCode control workspace is not a trusted directory")
+    return (
+        os.path.normcase(os.path.realpath(workspace_dir)),
+        workspace.st_dev,
+        workspace.st_ino,
+    )
