+def _path_is_within(root: str, candidate: str) -> bool:
+    """Return whether candidate resolves inside root, including on Windows."""
+    root_real = os.path.realpath(root)
+    candidate_real = os.path.realpath(candidate)
+    try:
+        common = os.path.commonpath((root_real, candidate_real))
+    except ValueError:
+        return False
+    return os.path.normcase(common) == os.path.normcase(root_real)
+
+
+def _remove_stale_output(workspace_dir: str, output_path: str) -> None:
+    """Remove only an exact stale file entry below the workspace."""
+    if not _path_is_within(workspace_dir, os.path.dirname(output_path)):
+        raise RuntimeError("Evaluation output path escapes the task workspace")
+    if not os.path.lexists(output_path):
+        return
+    stale_output = os.lstat(output_path)
+    if not (
+        stat.S_ISREG(stale_output.st_mode)
+        or stat.S_ISLNK(stale_output.st_mode)
+    ):
+        raise RuntimeError("Existing evaluation report or run result is not a removable file")
+    os.unlink(output_path)
+
+
+def _read_verified_utf8(root_dir: str, source_path: str) -> tuple[bytes, str]:
+    """Read one in-root regular file through the descriptor whose identity was checked."""
+    descriptor: int | None = None
+    before = os.lstat(source_path)
+    if (
+        stat.S_ISLNK(before.st_mode)
+        or not stat.S_ISREG(before.st_mode)
+        or not _path_is_within(root_dir, source_path)
+    ):
+        raise OSError("Untrusted UTF-8 source")
+    flags = os.O_RDONLY | getattr(os, "O_BINARY", 0)
+    flags |= getattr(os, "O_NOFOLLOW", 0)
+    try:
+        descriptor = os.open(source_path, flags)
+        opened = os.fstat(descriptor)
+        if (
+            not stat.S_ISREG(opened.st_mode)
+            or (before.st_dev, before.st_ino) != (opened.st_dev, opened.st_ino)
+        ):
+            raise OSError("UTF-8 source changed before open")
+        stream = os.fdopen(descriptor, "rb")
+        descriptor = None
+        with stream:
+            raw = stream.read()
+        return raw, raw.decode("utf-8")
+    finally:
+        if descriptor is not None:
+            os.close(descriptor)
+
+
+def _load_verified_json(workspace_dir: str, output_path: str) -> tuple[bool, object | None]:
+    """Load JSON from the same regular-file descriptor whose identity was checked."""
+    try:
+        _, text = _read_verified_utf8(workspace_dir, output_path)
+        payload = json.loads(text)
+    except (FileNotFoundError, OSError, TypeError, ValueError):
+        return False, None
+    return True, payload
+
+
+def _start_without_phycode_environment(proc: multiprocessing.Process) -> None:
+    """Start an evaluator child without leaking white-provider credentials."""
+    saved = {name: os.environ.pop(name) for name in PHYCODE_PROVIDER_NAMES if name in os.environ}
+    try:
+        proc.start()
+    finally:
+        os.environ.update(saved)
+
