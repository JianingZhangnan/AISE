+def _verify_phycode_control(
+    workspace_dir: str,
+    control_name: str,
+    workspace_identity: tuple[str, int, int],
+    target_identity: tuple[int, int] | None,
+    directory_descriptor: int | None = None,
+) -> None:
+    if _phycode_workspace_identity(workspace_dir) != workspace_identity:
+        raise RuntimeError("PhyCode control workspace changed")
+    target_path = os.path.join(workspace_dir, control_name)
+    if not _path_is_within(workspace_identity[0], target_path):
+        raise RuntimeError("PhyCode control destination escapes the workspace")
+    if target_identity is None:
+        if os.path.lexists(target_path):
+            raise RuntimeError("PhyCode control destination already exists")
+        return
+    if directory_descriptor is not None:
+        anchored = os.stat(
+            control_name,
+            dir_fd=directory_descriptor,
+            follow_symlinks=False,
+        )
+        if (
+            not stat.S_ISREG(anchored.st_mode)
+            or (anchored.st_dev, anchored.st_ino) != target_identity
+        ):
+            raise RuntimeError("PhyCode control target changed")
+    current = os.lstat(target_path)
+    if (
+        not stat.S_ISREG(current.st_mode)
+        or _is_reparse_point(current)
+        or (current.st_dev, current.st_ino) != target_identity
+        or not _path_is_within(workspace_identity[0], target_path)
+    ):
+        raise RuntimeError("PhyCode control target changed")
