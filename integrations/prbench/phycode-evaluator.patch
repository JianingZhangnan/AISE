+        target_path = os.path.join(workspace_dir, control_name)
+        if not _path_is_within(workspace_identity[0], target_path):
+            raise RuntimeError("PhyCode control destination escapes the workspace")
+        if not os.path.lexists(target_path):
+            existing.append(False)
+            continue
+        try:
+            actual, _ = _read_verified_utf8(workspace_dir, target_path)
+        except (OSError, TypeError, ValueError):
+            raise RuntimeError("Existing PhyCode control is unsafe") from None
+        if (
+            actual != payload
+            or _phycode_workspace_identity(workspace_dir) != workspace_identity
+        ):
+            raise RuntimeError("Existing PhyCode control does not match snapshot")
+        existing.append(True)
+    if _phycode_workspace_identity(workspace_dir) != workspace_identity:
+        raise RuntimeError("PhyCode control workspace changed")
