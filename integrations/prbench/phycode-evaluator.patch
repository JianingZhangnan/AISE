+def _write_phycode_control(
+    workspace_dir: str,
+    control_name: str,
+    payload: bytes,
+) -> None:
+    """Exclusively publish bytes; path-only platforms fail on observed swaps."""
+    if (
+        not isinstance(payload, bytes)
+        or not control_name
+        or os.path.basename(control_name) != control_name
+    ):
+        raise RuntimeError("Invalid PhyCode control payload")
+    workspace_identity = _phycode_workspace_identity(workspace_dir)
+    target_path = os.path.join(workspace_dir, control_name)
+    _verify_phycode_control(
+        workspace_dir, control_name, workspace_identity, None
+    )
