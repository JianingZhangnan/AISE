index 9c1f2b4..2bd3ef3 100644
--- a/src/my_util/docker_manager.py
+++ b/src/my_util/docker_manager.py
@@ -16,0 +17,5 @@ logger = logging.getLogger(__name__)
+PHYCODE_UV_IMAGE = (
+    "ghcr.io/astral-sh/uv@"
+    "sha256:5c3ab83183a73c5d319a77009eb425b60d5bb937f339fb7876788ebf567baf48"
+)
+
@@ -37,0 +43 @@ class DockerEnvironment:
+        phycode_wheel: str | None = None,
@@ -45,0 +52 @@ class DockerEnvironment:
+        self.phycode_wheel = phycode_wheel
@@ -115,0 +123,47 @@ class DockerEnvironment:
+    def install_phycode(self) -> bool:
+        """Install the adapter-staged PhyCode wheel inside the container."""
+        if self.container is None or not self.phycode_wheel:
+            return False
+        if not os.path.isfile(self.phycode_wheel):
+            return False
+        helper = None
+        try:
+            import io
+
+            # The official python:3.11-slim task image does not include uv.
+            # Copy the binary from Astral's pinned linux/amd64 image without
+            # introducing pip as a package-management bootstrap path.
+            self.client.images.pull(PHYCODE_UV_IMAGE)
+            helper = self.client.containers.create(PHYCODE_UV_IMAGE)
+            archive, _ = helper.get_archive("/uv")
+            tar_stream = io.BytesIO()
+            for chunk in archive:
+                tar_stream.write(chunk)
+            tar_stream.seek(0)
+            self.container.put_archive("/usr/local/bin", tar_stream)
+            uv_check = self.exec_command("chmod 0755 /usr/local/bin/uv && uv --version")
+            if uv_check["exit_code"] != 0:
+                return False
+            self.copy_file_to(
+                self.phycode_wheel, "/tmp/phycode-0.1.0-py3-none-any.whl"
+            )
+        except Exception:
+            return False
+        finally:
+            if helper is not None:
+                try:
+                    helper.remove(force=True)
+                except Exception:
+                    pass
+        result = self.exec_command(
+            "uv pip install --system /tmp/phycode-0.1.0-py3-none-any.whl",
+            timeout=300,
+        )
+        return result["exit_code"] == 0
+
+    def check_phycode_health(self) -> bool:
+        """Check whether the installed PhyCode CLI is available."""
+        if self.container is None:
+            return False
+        return self.exec_command("phycode prbench run --help")["exit_code"] == 0
+
