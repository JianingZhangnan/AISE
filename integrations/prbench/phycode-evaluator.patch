+def _is_reparse_point(file_status: os.stat_result) -> bool:
+    marker = getattr(stat, "FILE_ATTRIBUTE_REPARSE_POINT", 0x400)
+    return bool(getattr(file_status, "st_file_attributes", 0) & marker)
+
