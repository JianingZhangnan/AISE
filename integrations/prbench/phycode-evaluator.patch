+    allowed_constraint_fields = {
+        "path", "csv_header", "csv_rows", "csv_data_row_count",
+    }
+    for constraint in constraints:
+        if not isinstance(constraint, dict) or set(constraint) - allowed_constraint_fields:
+            raise RuntimeError(error)
+        path = constraint.get("path")
+        if not isinstance(path, str) or not path:
+            raise RuntimeError(error)
+        key = path.replace("\\", "/")
