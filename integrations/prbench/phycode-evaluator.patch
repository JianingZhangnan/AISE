+def _copy_phycode_controls(
+    task_config: dict,
+    task_dir: str,
+    workspace_dir: str,
+    contract_file: str | None,
+    approvals_file: str | None,
+    code_only: bool,
+) -> None:
+    """Prepare public runner inputs without deriving any approval grants."""
+    instruction_file = task_config.get("instruction_file", "")
+    paper_file = task_config.get("paper", {}).get("paper_file", "")
+    if not instruction_file or not paper_file:
+        raise RuntimeError("PhyCode requires declared public instruction and paper files")
+
+    instruction_src = os.path.join(task_dir, instruction_file)
+    instruction_dst = os.path.join(workspace_dir, os.path.basename(instruction_file))
+    if not os.path.isfile(instruction_src):
+        raise RuntimeError("Declared public instruction file is unavailable")
+    if os.path.lexists(instruction_dst):
+        os.remove(instruction_dst)
+    shutil.copy2(instruction_src, instruction_dst)
+
+    copied_public_files = [paper_file, *task_config.get("input_files", [])]
+    for public_file in copied_public_files:
+        copied_path = os.path.join(workspace_dir, os.path.basename(public_file))
+        if not os.path.isfile(copied_path):
+            raise RuntimeError(
+                "Declared public paper/input file was not copied to the workspace"
+            )
+
+    contract_dst = os.path.join(workspace_dir, "task_contract.json")
+    approvals_dst = os.path.join(workspace_dir, "phycode-approvals.json")
+    for destination in (contract_dst, approvals_dst):
+        if os.path.lexists(destination):
+            if os.path.isdir(destination) and not os.path.islink(destination):
+                raise RuntimeError("PhyCode control destination is not a file")
+            os.remove(destination)
+
+    if contract_file:
+        if not os.path.isfile(contract_file):
+            raise RuntimeError("Explicit PhyCode contract is unavailable")
+        shutil.copy2(contract_file, contract_dst)
+    else:
+        expected_config = task_config.get("expected_outputs", {})
+        if code_only:
+            expected_config = task_config.get("code_only", {}).get(
+                "expected_outputs", expected_config
+            )
+        expected_files = [
+            path
+            for group in ("code", "data")
+            for path in expected_config.get(group, [])
+        ]
+        contract = {
+            "instruction_file": os.path.basename(instruction_file),
+            "paper_file": os.path.basename(paper_file),
+            "input_files": [
+                os.path.basename(path) for path in task_config.get("input_files", [])
+            ],
+            "expected_files": expected_files,
+            "constraints": [],
+        }
+        with open(contract_dst, "w", encoding="utf-8") as handle:
+            json.dump(contract, handle, indent=2)
+            handle.write("\n")
+
+    if approvals_file:
+        if not os.path.isfile(approvals_file):
+            raise RuntimeError("Explicit PhyCode approval manifest is unavailable")
+        shutil.copy2(approvals_file, approvals_dst)
+    else:
+        with open(approvals_dst, "w", encoding="utf-8") as handle:
+            json.dump({"grants": []}, handle, indent=2)
+            handle.write("\n")
+
