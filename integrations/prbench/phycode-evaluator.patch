+        remaining = memoryview(payload)
+        while remaining:
+            written = os.write(descriptor, remaining)
+            if written <= 0:
+                raise OSError("Failed to write PhyCode control payload")
+            remaining = remaining[written:]
+        if (os.fstat(descriptor).st_dev, os.fstat(descriptor).st_ino) != created_identity:
+            raise RuntimeError("PhyCode control descriptor changed after write")
+        _verify_phycode_control(
+            workspace_dir,
+            control_name,
+            workspace_identity,
+            created_identity,
+            directory_descriptor,
+        )
+    finally:
+        try:
+            if descriptor is not None:
+                os.close(descriptor)
+        finally:
+            if directory_descriptor is not None:
+                os.close(directory_descriptor)
+
