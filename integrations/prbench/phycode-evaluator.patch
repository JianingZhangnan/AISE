diff --git a/src/my_util/agent_env.py b/src/my_util/agent_env.py
index d0ae5f5..be5ce69 100644
--- a/src/my_util/agent_env.py
+++ b/src/my_util/agent_env.py
@@ -14,0 +15,7 @@ import os
+PHYCODE_PROVIDER_NAMES = (
+    "PHYCODE_API_KEY",
+    "PHYCODE_BASE_URL",
+    "PHYCODE_MODEL",
+)
+
+
@@ -134,0 +142,29 @@ def resolve_opencode_env() -> dict[str, str]:
+def resolve_phycode_env() -> dict[str, str]:
+    """Resolve only the provider variables consumed by the PhyCode runner."""
+    env: dict[str, str] = {}
+    for name in PHYCODE_PROVIDER_NAMES:
+        value = os.environ.get(name, "").strip()
+        if value:
+            env[name] = value
+    return env
+
+
+def clear_phycode_environment(
+    provider_env: dict[str, str], process_env: dict[str, str] | None = None,
+) -> None:
+    """Remove white-provider values from every transient host mapping."""
+    provider_env.clear()
+    for name in PHYCODE_PROVIDER_NAMES:
+        os.environ.pop(name, None)
+        if process_env is not None:
+            process_env.pop(name, None)
+
+
+def run_with_phycode_cleanup(action, provider_env, process_env=None):
+    """Run one spawn action and clear credentials on success or failure."""
+    try:
+        return action()
+    finally:
+        clear_phycode_environment(provider_env, process_env)
+
+
@@ -138,0 +175,2 @@ def resolve_env(agent_type: str) -> dict[str, str]:
+    if agent_type == "phycode":
+        return resolve_phycode_env()
@@ -149,0 +188,6 @@ def build_docker_exec_env_flags(agent_type: str) -> list[str]:
+    if agent_type == "phycode":
+        # Values are supplied only in the docker CLI child environment. They
+        # never enter the host subprocess argv or the persistent container env.
+        for key in PHYCODE_PROVIDER_NAMES:
+            flags.extend(["-e", key])
+        return flags
